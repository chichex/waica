{
  "name": "@waica/overlay",
  "version": "0.1.0",
  "description": "Waica in-game inspector overlay — live-edit behavior params and persist them to the project",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/chichex/waica",
    "directory": "packages/overlay"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./vite": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@waica/engine": "workspace:^"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vite": "^8.1.5"
  }
}
